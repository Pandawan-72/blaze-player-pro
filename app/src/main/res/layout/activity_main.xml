<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- MINI PLAYER persistant -->
    <LinearLayout
        android:id="@+id/miniPlayerBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_mini_player"
        android:elevation="8dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivMiniArtwork"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_artwork"
            android:clipToOutline="true"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre inconnu"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:fontFamily="@font/oswald"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/green_accent"
                android:textSize="12sp"
                android:fontFamily="@font/oswald" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMiniPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Précédent" />

        <ImageButton
            android:id="@+id/btnMiniPlayPause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_play_button"
            android:src="@drawable/ic_play"
            android:tint="@color/background"
            android:padding="10dp"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/btnMiniNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Suivant" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
