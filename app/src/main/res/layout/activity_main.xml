<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- MINI PLAYER persistant - style nav-audio -->
    <LinearLayout
        android:id="@+id/miniPlayerBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="0dp"
        android:layout_marginBottom="0dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_mini_player"
        android:elevation="16dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Artwork + play overlay -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/ivMiniArtwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumbnail"
                android:clipToOutline="true"
                android:contentDescription="@null" />

        </FrameLayout>

        <!-- Titre + artiste -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre inconnu"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:fontFamily="sans-serif-condensed"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/green_accent"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Contrôles : prev | pause | next -->
        <ImageButton
            android:id="@+id/btnMiniPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/on_surface"
            android:contentDescription="Précédent" />

        <ImageButton
            android:id="@+id/btnMiniPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_pause"
            android:tint="@color/on_surface"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/btnMiniNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/on_surface"
            android:contentDescription="Suivant" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
