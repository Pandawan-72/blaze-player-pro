<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Retour" />

            <TextView
                android:id="@+id/tvNowPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="En lecture"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:letterSpacing="0.1" />

        </RelativeLayout>

        <!-- ARTWORK + BONHOMMES -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp">

            <!-- Cover carrée centrée -->
            <ImageView
                android:id="@+id/ivArtwork"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_artwork"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:outlineProvider="background"
                android:contentDescription="@null" />

            <!-- Bonhomme féminin gauche centré verticalement -->
            <ImageView
                android:id="@+id/ivPixelCharLeft"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                android:layout_toLeftOf="@id/ivArtwork"
                android:layout_marginRight="8dp"
                android:src="@drawable/pixel_dancer_f1"
                android:contentDescription="@null" />

            <!-- Bonhomme masculin droite centré verticalement -->
            <ImageView
                android:id="@+id/ivPixelChar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                android:layout_toRightOf="@id/ivArtwork"
                android:layout_marginLeft="8dp"
                android:src="@drawable/pixel_dancer_1"
                android:contentDescription="@null" />

        </RelativeLayout>

        <!-- MÉTADONNÉES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre inconnu"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artiste inconnu"
                android:textColor="@color/green_accent"
                android:textSize="14sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCodec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:background="@drawable/bg_badge_orange"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/orange_accent"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvBitrate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- BARRE DE PROGRESSION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="8dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/green_accent"
                android:thumbTint="@color/green_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- LIGNE EQ + CONTRÔLES + SHUFFLE/REPEAT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingBottom="4dp">

            <!-- EQ -->
            <ImageButton
                android:id="@+id/btnEq"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_equalizer"
                android:tint="@color/purple_accent"
                android:contentDescription="Equalizer" />

            <!-- SLEEP TIMER -->
            <ImageButton
                android:id="@+id/btnSleepTimer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_sleep_timer"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Sleep Timer" />

            <!-- SPACER -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <!-- PREV -->
            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:tint="@color/on_background"
                android:contentDescription="Précédent" />

            <!-- REWIND -->
            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_replay_10"
                android:tint="@color/on_background"
                android:contentDescription="-10s" />

            <!-- PLAY/PAUSE -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_play_audio"
                android:src="@drawable/ic_pause"
                android:tint="@color/background"
                android:contentDescription="Lecture/Pause"
                android:layout_marginHorizontal="4dp" />

            <!-- FORWARD -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_forward_10"
                android:tint="@color/on_background"
                android:contentDescription="+10s" />

            <!-- NEXT -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/on_background"
                android:contentDescription="Suivant" />

            <!-- SPACER -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <!-- REPEAT -->
            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_repeat"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Répéter" />

            <!-- SHUFFLE -->
            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Aléatoire" />

        </LinearLayout>

        <!-- PLAYLIST HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LISTE DE LECTURE"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCleanPlaylist"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Nettoyer"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="#33FFFFFF"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_close"
                app:iconSize="14dp"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFolder"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Piste / Dossier"
                app:icon="@drawable/ic_add_circle"
                app:iconSize="16dp"
                app:iconTint="#FF000000"
                app:iconGravity="textStart"
                android:textSize="12sp"
                android:textColor="#FF000000"
                android:paddingHorizontal="14dp"
                app:backgroundTint="@color/blue_accent"
                app:cornerRadius="20dp" />

        </LinearLayout>

        <!-- PLAYLIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPlaylist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

</LinearLayout>
