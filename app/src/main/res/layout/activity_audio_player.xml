<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- CONTENU PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Retour" />

            <TextView
                android:id="@+id/tvNowPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="EN LECTURE"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/oswald"
                android:letterSpacing="0.15" />

            <ImageButton
                android:id="@+id/btnPlaylistSheet"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_layout_list"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Playlist" />

        </RelativeLayout>

        <!-- ARTWORK carré centré -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp">

            <ImageView
                android:id="@+id/ivArtwork"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumbnail"
                android:clipToOutline="true" />

        </LinearLayout>



        <!-- TITRE + ARTISTE centrés -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Titre inconnu"
                android:textColor="@color/on_surface"
                android:textSize="22sp"
                android:fontFamily="@font/oswald"
                android:ellipsize="end"
                android:singleLine="true"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artiste inconnu"
                android:textColor="@color/green_accent"
                android:textSize="14sp"
                android:fontFamily="@font/oswald"
                android:layout_marginTop="4dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="@font/oswald"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- CODEC + BITRATE sous artiste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tvCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="11sp"
                android:textColor="@color/blue_accent"
                android:fontFamily="@font/oswald"
                android:text="MP3"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvBitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/oswald"
                android:visibility="gone" />

        </LinearLayout>

        <!-- BOUTONS SECONDAIRES : EQ / SLEEP / CODEC / BITRATE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/btnEq">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_equalizer"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="EQ" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Égaliseur"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:fontFamily="@font/oswald"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/btnSleepTimer">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_timer"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Timer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minuteur"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:fontFamily="@font/oswald"
                    android:layout_marginTop="2dp" />

            </LinearLayout>





        </LinearLayout>

        <!-- BONHOMMES sous les contrôles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="64dp">

            <ImageView
                android:id="@+id/ivPixelCharLeft"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                android:src="@drawable/pixel_dancer_f1"
                android:contentDescription="@null" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/ivPixelChar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                android:src="@drawable/pixel_dancer_1"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- SEEKBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/green_accent"
                android:thumbTint="@color/green_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="@font/oswald" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="@font/oswald" />

            </LinearLayout>

        </LinearLayout>

        <!-- CONTRÔLES PRINCIPAUX -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Aléatoire" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:tint="@color/on_surface"
                android:contentDescription="Précédent" />

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_replay_10"
                android:tint="@color/on_surface_variant"
                android:contentDescription="-10s"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_play_button"
                android:src="@drawable/ic_play"
                android:tint="@color/background"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:contentDescription="Lecture/Pause" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_forward_10"
                android:tint="@color/on_surface_variant"
                android:contentDescription="+10s"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/on_surface"
                android:contentDescription="Suivant" />

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_repeat"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Répéter" />

        </LinearLayout>



    </LinearLayout>

    <!-- BOTTOM SHEET PLAYLIST -->
    <LinearLayout
        android:id="@+id/playlistSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="8dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true"
        app:behavior_skipCollapsed="true">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LISTE DE LECTURE"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/oswald"
                android:letterSpacing="0.1" />

            <ImageButton
                android:id="@+id/btnAddFolder"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add_circle"
                android:tint="@color/green_accent"
                android:contentDescription="Ajouter" />

            <ImageButton
                android:id="@+id/btnCleanPlaylist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_remove_circle"
                android:tint="#FF4444"
                android:contentDescription="Nettoyer"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPlaylist"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:overScrollMode="never" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
