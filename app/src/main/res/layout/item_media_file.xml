<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="8dp"
    android:background="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_thumbnail"
        android:layout_marginEnd="12dp"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivPlayOverlay"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_small"
            android:contentDescription="@null" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/tvResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_green"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/green_accent"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginEnd="4dp"
                android:text="MP4" />

            <TextView
                android:id="@+id/tvVideoCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:textColor="@color/blue_accent"
                android:layout_marginEnd="4dp"
                android:text="H.264"
                android:visibility="visible" />

            <TextView
                android:id="@+id/tvAudioCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginEnd="6dp"
                android:text="AAC"
                android:visibility="visible" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#1AFFFFFF" />

            <View
                android:id="@+id/progressFill"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:background="@color/green_accent"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        android:contentDescription="Options" />

</LinearLayout>
