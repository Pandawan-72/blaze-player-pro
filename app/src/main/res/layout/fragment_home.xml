<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    >

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@mipmap/ic_launcher_round"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BlazePlayer"
                        android:textColor="@color/on_background"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.04" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnCast"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_cast"
                    android:contentDescription="Chromecast"
                    android:tint="@color/on_surface_variant" />

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Rechercher"
                    android:tint="@color/on_surface_variant" />

            </LinearLayout>

            <!-- TOP TABS -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                app:tabBackground="@android:color/transparent"
                app:tabGravity="start"
                app:tabIndicatorHeight="0dp"
                app:tabMode="scrollable"
                app:tabPaddingStart="4dp"
                app:tabPaddingEnd="4dp"
                app:tabSelectedTextColor="@color/green_accent"
                app:tabTextColor="@color/on_surface_variant"
                app:tabTextAppearance="@style/TabTextAppearance" />

            <!-- HERO CARD -->
            <FrameLayout
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_hero_card"
                android:clipToOutline="true">

                <!-- Grille décorative -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_grid_overlay" />

                <!-- Bouton play central -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_play_button"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="3dp"
                        android:src="@drawable/ic_play"
                        android:tint="@color/green_accent"
                        android:contentDescription="Lecture" />
                </FrameLayout>

                <!-- Badge source -->
                <TextView
                    android:id="@+id/tvHeroBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="SMB"
                    android:textColor="@color/green_accent"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06" />

                <!-- Overlay bas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_bottom"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tvHeroTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aucune lecture récente"
                        android:textColor="@color/on_background"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >

                        <TextView
                            android:id="@+id/tvHeroDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvHeroResolution"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Barre de progression -->
                    <View
                        android:id="@+id/progressBg"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="#1FFFFFFF" />

                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="-2dp"
                        android:background="@color/green_accent" />

                </LinearLayout>

            </FrameLayout>

            <!-- SECTION RÉSEAU -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BIBLIOTHÈQUE RÉSEAU"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBrowseNetwork"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Naviguer"
                    android:textSize="11sp"
                    android:textColor="@color/blue_accent"
                    app:strokeColor="@color/blue_accent"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_folder_open"
                    app:iconSize="13dp"
                    app:iconTint="@color/blue_accent"
                    app:iconGravity="textStart"
                    android:paddingHorizontal="10dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/listNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp" />

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="14dp"
                android:background="#0FFFFFFF" />

            <!-- SECTION LOCAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="STOCKAGE LOCAL"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBrowseLocal"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Naviguer"
                    android:textSize="11sp"
                    android:textColor="@color/green_accent"
                    app:strokeColor="@color/green_accent"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_folder_open"
                    app:iconSize="13dp"
                    app:iconTint="@color/green_accent"
                    app:iconGravity="textStart"
                    android:paddingHorizontal="10dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/listLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
