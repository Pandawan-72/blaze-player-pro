<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="130dp"
                    android:layout_height="49dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:src="@drawable/logo_blaze"
                    android:scaleType="fitStart"
                    android:contentDescription="@null" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_surface_card"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Réglages" />

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSettings"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Rechercher" />

                <androidx.mediarouter.app.MediaRouteButton
                    android:id="@+id/btnCast"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSearch"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Chromecast" />

            </RelativeLayout>

            <!-- TABS avec icônes -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tabAll"
                        android:visibility="gone"
                        android:layout_width="0dp"
                        android:layout_height="0dp" />

                    <!-- Tab Local -->
                    <LinearLayout
                        android:id="@+id/tabLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_tab_active"
                        android:paddingHorizontal="16dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/tabLocalIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_folder_open"
                            android:tint="@color/green_accent"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tabLocalText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Local"
                            android:textColor="@color/green_accent"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:includeFontPadding="false" />

                    </LinearLayout>

                    <!-- Tab Réseau -->
                    <LinearLayout
                        android:id="@+id/tabNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_tab_inactive"
                        android:paddingHorizontal="16dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/tabNetworkIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_network"
                            android:tint="@color/on_surface_variant"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tabNetworkText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Réseau"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:includeFontPadding="false" />

                    </LinearLayout>

                    <!-- Tab Blaze Audio -->
                    <LinearLayout
                        android:id="@+id/tabAudio"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_tab_inactive"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/tabAudioIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_music_note_large"
                            android:tint="@color/on_surface_variant"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tabAudioText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blaze Audio"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:includeFontPadding="false" />

                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- SECTION RÉSEAU -->
            <LinearLayout
                android:id="@+id/sectionNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvSectionNetwork"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Historique réseau"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnBrowseNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Naviguer"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/green_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

            <!-- SECTION LOCAL -->
            <LinearLayout
                android:id="@+id/sectionLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvSectionLocal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Historique local"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnBrowseLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Naviguer"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/green_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="24dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/audioContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
