<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="76dp"
        android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="130dp"
                    android:layout_height="49dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:src="@drawable/logo_blaze"
                    android:scaleType="fitStart"
                    android:contentDescription="@null" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_surface_card"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Réglages" />

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSettings"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Rechercher" />

                <androidx.mediarouter.app.MediaRouteButton
                    android:id="@+id/btnCast"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSearch"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Chromecast" />

                <ImageButton
                    android:id="@+id/btnScreenCast"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnCast"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_screen_cast"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Caster l'écran du téléphone" />

            </RelativeLayout>


            <LinearLayout
                android:id="@+id/sectionNetwork"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvSectionNetwork"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/history_network"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnFavoritesNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/favorites"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"
                        android:paddingHorizontal="12dp"
                        app:backgroundTint="@color/surface_variant"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_star"
                        app:iconSize="14dp"
                        app:iconTint="@color/on_surface"
                        app:iconGravity="textStart" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnBrowseNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="@string/browse_files_network"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/green_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <!-- Playlists réseau sauvegardées -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_layout_list"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/playlists_label"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/btnPlaylistNetwork1"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnPlaylistNetwork2"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnPlaylistNetwork3"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="8dp"
                    android:clipToPadding="false" />

            </LinearLayout>

            <!-- SECTION LOCAL -->
            <LinearLayout
                android:id="@+id/sectionLocal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvSectionLocal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/history_local"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnFavoritesLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/favorites"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"
                        android:paddingHorizontal="12dp"
                        app:backgroundTint="@color/surface_variant"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_star"
                        app:iconSize="14dp"
                        app:iconTint="@color/on_surface"
                        app:iconGravity="textStart" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnBrowseLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="@string/browse_files_local"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/green_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <!-- Playlists locales sauvegardées -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_layout_list"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/playlists_label"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/btnPlaylistLocal1"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnPlaylistLocal2"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnPlaylistLocal3"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-condensed"
                        android:background="@drawable/bg_playlist_chip"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listLocal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="24dp"
                    android:clipToPadding="false" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionYoutube"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/youtubeSearchBarRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_field">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        android:tint="@color/on_surface_variant"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/editYoutubeSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/youtube_search_hint"
                        android:textColorHint="@color/on_surface_variant"
                        android:textColor="@color/on_surface"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />

                    <ImageView
                        android:id="@+id/btnCloseYoutubeSearch"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_close"
                        android:tint="@color/on_surface_variant"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Fermer la recherche" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/youtubeFavoritesHeaderRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/favorites"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:includeFontPadding="false"
                        android:id="@+id/btnCloseYoutubeFavorites"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="@string/action_close_favorites"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface"
                        android:paddingHorizontal="12dp"
                        app:backgroundTint="@color/surface_variant"
                        app:strokeColor="@color/outline_variant"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_close"
                        app:iconSize="14dp"
                        app:iconTint="@color/on_surface"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvYoutubeError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="8dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Résultats de recherche OU favoris (même liste réutilisée pour les deux, un
                     seul est actif à la fois) : visible dès qu'on quitte le contenu par défaut -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listYoutubeSearch"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="24dp"
                    android:clipToPadding="false"
                    android:visibility="gone" />

                <!-- Historique, visible par défaut (aucune recherche/favoris affichés) -->
                <LinearLayout
                    android:id="@+id/youtubeDefaultContent"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/history_label"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed" />

                        <com.google.android.material.button.MaterialButton
                            android:includeFontPadding="false"
                            android:id="@+id/btnYoutubeFavorites"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:text="@string/favorites"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface"
                            android:paddingHorizontal="12dp"
                            app:backgroundTint="@color/surface_variant"
                            app:strokeColor="@color/outline_variant"
                            app:strokeWidth="1dp"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_star"
                            app:iconSize="14dp"
                            app:iconTint="@color/on_surface"
                            app:iconGravity="textStart" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_layout_list"
                            android:tint="@color/on_surface_variant"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/playlists_label"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-condensed"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/btnPlaylistYoutube1"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:background="@drawable/bg_playlist_chip"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnPlaylistYoutube2"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:background="@drawable/bg_playlist_chip"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnPlaylistYoutube3"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-condensed"
                            android:background="@drawable/bg_playlist_chip"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/listYoutubeHistory"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:paddingHorizontal="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="24dp"
                        android:clipToPadding="false" />

                </LinearLayout>

            </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/audioContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Placeholder conservé pour compatibilité avec le code existant -->
    <TextView
        android:id="@+id/tabAll"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp" />

    <!-- BOTTOM NAV BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Tab Local -->
        <LinearLayout
            android:id="@+id/tabLocal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_tab_active"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tabLocalIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_folder_open"
                android:tint="@color/green_accent"
                android:layout_marginBottom="4dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tabLocalText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_local"
                android:textColor="@color/green_accent"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- Tab Réseau -->
        <LinearLayout
            android:id="@+id/tabNetwork"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tabNetworkIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_network"
                android:tint="@color/on_surface_variant"
                android:layout_marginBottom="4dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tabNetworkText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_network"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- Tab Blaze Tube -->
        <LinearLayout
            android:id="@+id/tabYoutube"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tabYoutubeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_youtube_tab"
                android:tint="@color/on_surface_variant"
                android:layout_marginBottom="4dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tabYoutubeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blaze Tube"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- Tab Blaze Audio -->
        <LinearLayout
            android:id="@+id/tabAudio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_tab_inactive"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tabAudioIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_music_note_large"
                android:tint="@color/on_surface_variant"
                android:layout_marginBottom="4dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tabAudioText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blaze Audio"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
