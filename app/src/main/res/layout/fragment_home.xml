<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="130dp"
                    android:layout_height="49dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/btnCast"
                    android:src="@drawable/logo_blaze"
                    android:scaleType="fitStart"
                    android:contentDescription="@null" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_surface_card"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Réglages" />

                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSettings"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Rechercher"
                    android:tint="@color/on_surface_variant" />

                <ImageButton
                    android:id="@+id/btnCast"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/btnSearch"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_cast"
                    android:contentDescription="Chromecast"
                    android:tint="@color/on_surface_variant" />

            </RelativeLayout>

            <!-- TABS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabAll"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_tab_active"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Tous"
                        android:textColor="@color/green_accent"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tabNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_tab_inactive"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Réseau"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tabLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_tab_inactive"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Local"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- HERO CARD -->
            <FrameLayout
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_hero_card"
                android:clipToOutline="true"
                android:foreground="?attr/selectableItemBackground">

                <!-- THUMBNAIL -->
                <ImageView
                    android:id="@+id/ivHeroThumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@color/surface_variant"
                    android:contentDescription="@null" />

                <!-- LABEL DERNIER FICHIER LU -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="Dernier fichier lu"
                    android:textColor="@color/on_background"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- BADGE SOURCE -->
                <TextView
                    android:id="@+id/tvHeroBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="LOCAL"
                    android:textColor="@color/green_accent"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

                <!-- BOUTON PLAY -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_circle"
                    android:contentDescription="Lecture" />

                <!-- OVERLAY BAS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_bottom"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tvHeroTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aucune lecture récente"
                        android:textColor="@color/on_background"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:layout_marginBottom="3dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvHeroDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:id="@+id/tvHeroResolution"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="1dp"
                            android:text=""
                            android:textColor="@color/green_accent"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/tvHeroFormat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_gray"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="1dp"
                            android:text=""
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/tvHeroVideoCodec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_blue"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="1dp"
                            android:text=""
                            android:textColor="@color/blue_accent"
                            android:textSize="10sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/tvHeroAudioCodec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_gray"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="1dp"
                            android:text=""
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="5dp">
                        <View
                            android:id="@+id/progressBg"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="#1FFFFFFF" />
                        <View
                            android:id="@+id/progressFill"
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:background="@color/green_accent" />
                    </FrameLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- SECTION RÉSEAU -->
            <LinearLayout
                android:id="@+id/sectionNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/tvSectionNetwork"
                        android:text="HISTORIQUE RÉSEAU (3 DERNIERS)"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBrowseNetwork"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Naviguer"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/blue_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/listNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="14dp"
                android:background="#0FFFFFFF" />

            <!-- SECTION LOCAL -->
            <LinearLayout
                android:id="@+id/sectionLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/tvSectionLocal"
                        android:text="HISTORIQUE LOCAL (3 DERNIERS)"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBrowseLocal"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Naviguer"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:paddingHorizontal="14dp"
                        app:backgroundTint="@color/green_accent"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_folder_open"
                        app:iconSize="14dp"
                        app:iconTint="#FF000000"
                        app:iconGravity="textStart" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/listLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="24dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
