<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_layout_list"
        android:tint="@color/green_accent"
        android:layout_marginEnd="12dp"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlaylistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:fontFamily="sans-serif-condensed" />

        <TextView
            android:id="@+id/tvPlaylistCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnRenamePlaylist"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_edit"
        android:tint="@color/on_surface_variant"
        android:contentDescription="Renommer" />

    <ImageButton
        android:id="@+id/btnDeletePlaylist"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_remove_circle"
        android:tint="#FF4444"
        android:layout_marginStart="4dp"
        android:contentDescription="Supprimer" />

</LinearLayout>