<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- PlayerView Media3 : gere automatiquement Surface/Texture, rotation, ratio -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="surface_view" />

    <!-- UI OVERLAY -->
    <LinearLayout
        android:id="@+id/uiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@drawable/gradient_top">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:contentDescription="Retour" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-condensed"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginHorizontal="8dp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCast"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_cast"
                android:tint="#99FFFFFF"
                android:contentDescription="Cast" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- BOTTOM BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:background="@drawable/gradient_bottom">

            <!-- Wrapper pour éviter que le thumb soit rogné -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:paddingHorizontal="7dp">
                <FrameLayout
                    android:id="@+id/progressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_gravity="center_vertical" android:background="#33FFFFFF" />
                    <View android:id="@+id/progressBuffer" android:layout_width="0dp" android:layout_height="3dp" android:layout_gravity="center_vertical|start" android:background="#22FFFFFF" />
                    <View android:id="@+id/progressFill" android:layout_width="0dp" android:layout_height="3dp" android:layout_gravity="center_vertical|start" android:background="@color/green_accent" />
                    <View android:id="@+id/progressThumb" android:layout_width="14dp" android:layout_height="14dp" android:layout_gravity="center_vertical|start" android:background="@drawable/bg_progress_thumb" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/tvCurrentTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0:00:00" android:textColor="#FFFFFF" android:textSize="12sp" android:fontFamily="monospace" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" / " android:textColor="#55FFFFFF" android:textSize="12sp" />
                <TextView android:id="@+id/tvTotalTime" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0:00:00" android:textColor="#55FFFFFF" android:textSize="12sp" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="horizontal" android:gravity="center">
                    <LinearLayout android:id="@+id/btnSubtitles" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_subtitles" android:tint="#CCFFFFFF" android:contentDescription="ST" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ST" android:textColor="#66FFFFFF" android:textSize="9sp" android:layout_marginTop="3dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btnAudio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_language" android:tint="#CCFFFFFF" android:contentDescription="Audio" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUDIO" android:textColor="#66FFFFFF" android:textSize="9sp" android:layout_marginTop="3dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btnRewind" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
                        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_rewind_10" android:tint="#FFFFFF" android:contentDescription="Reculer" />
                        <TextView android:id="@+id/tvRewindLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-10s" android:textColor="#66FFFFFF" android:textSize="9sp" android:layout_marginTop="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout android:id="@+id/btnPlayPause" android:layout_width="64dp" android:layout_height="64dp" android:background="@drawable/bg_play_btn_player" android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/ivPlayPause" android:layout_width="30dp" android:layout_height="30dp" android:layout_gravity="center" android:src="@drawable/ic_play" android:tint="#FFFFFF" android:contentDescription="Play" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="horizontal" android:gravity="center">
                    <LinearLayout android:id="@+id/btnForward" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
                        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_forward_10" android:tint="#FFFFFF" android:contentDescription="Avancer" />
                        <TextView android:id="@+id/tvForwardLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+10s" android:textColor="#66FFFFFF" android:textSize="9sp" android:layout_marginTop="3dp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btnRatio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_aspect_ratio" android:tint="#CCFFFFFF" android:contentDescription="Ratio" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RATIO" android:textColor="#66FFFFFF" android:textSize="9sp" android:layout_marginTop="3dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ZONES GESTUELLES -->
    <FrameLayout android:id="@+id/touchZoneLeft" android:layout_width="56dp" android:layout_height="200dp" android:layout_gravity="center_vertical|start" android:layout_marginStart="12dp" android:background="@drawable/bg_touch_zone" android:clickable="true" android:focusable="true" android:clipToOutline="true" android:visibility="gone">
        <View android:id="@+id/touchZoneLeftFill" android:layout_width="match_parent" android:layout_height="0dp" android:layout_gravity="bottom" android:background="@drawable/bg_fill_yellow" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_sun" android:tint="#FFD43B" android:contentDescription="@null" />
            <TextView android:id="@+id/tvBrightnessZone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#FFD43B" android:textSize="10sp" android:layout_marginTop="6dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout android:id="@+id/touchZoneRight" android:layout_width="56dp" android:layout_height="200dp" android:layout_gravity="center_vertical|end" android:layout_marginEnd="12dp" android:background="@drawable/bg_touch_zone" android:clickable="true" android:focusable="true" android:clipToOutline="true" android:visibility="gone">
        <View android:id="@+id/touchZoneRightFill" android:layout_width="match_parent" android:layout_height="0dp" android:layout_gravity="bottom" android:background="@drawable/bg_fill_blue" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_volume" android:tint="#4FC3F7" android:contentDescription="@null" />
            <TextView android:id="@+id/tvVolumeZone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#4FC3F7" android:textSize="10sp" android:layout_marginTop="6dp" />
        </LinearLayout>
    </FrameLayout>

    <TextView android:id="@+id/seekIndicator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:background="@drawable/bg_seek_indicator" android:paddingHorizontal="20dp" android:paddingVertical="8dp" android:text="0:00:00" android:textColor="#FFFFFF" android:textSize="16sp" android:fontFamily="sans-serif-condensed" android:visibility="gone" />

</FrameLayout>
