<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_surface_card"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Retour"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ajouter des pistes"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAll"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Tout ajouter"
            app:icon="@drawable/ic_add_circle"
            app:iconSize="16dp"
            app:iconTint="#FF000000"
            app:iconGravity="textStart"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:paddingHorizontal="12dp"
            android:layout_marginEnd="6dp"
            app:backgroundTint="@color/orange_accent"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Pistes"
            app:icon="@drawable/ic_add_circle"
            app:iconSize="16dp"
            app:iconTint="#FF000000"
            app:iconGravity="textStart"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:paddingHorizontal="14dp"
            app:backgroundTint="@color/green_accent"
            app:cornerRadius="20dp" />

    </LinearLayout>

    <!-- TABS LOCAL / RÉSEAU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLocal"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="📱 Local"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:paddingHorizontal="14dp"
            app:backgroundTint="@color/green_accent"
            app:cornerRadius="20dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNetwork"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="🌐 Réseau"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:paddingHorizontal="14dp"
            app:backgroundTint="@color/blue_accent"
            app:cornerRadius="20dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFolder"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="📂 Dossiers"
            android:textSize="12sp"
            android:textColor="#000000"
            android:paddingHorizontal="14dp"
            app:backgroundTint="#FFB3C6"
            app:cornerRadius="20dp" />

    </LinearLayout>

    <!-- COMPTEUR -->
    <TextView
        android:id="@+id/tvSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:text="0 piste sélectionnée"
        android:textColor="@color/green_accent"
        android:textSize="12sp" />

    <!-- LISTE -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAudio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />

</LinearLayout>
