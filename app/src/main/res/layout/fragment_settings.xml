<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Retour"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Paramètres"
            android:textColor="@color/on_background"
            android:textSize="22sp"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- PRO -->
            <LinearLayout
                android:id="@+id/btnBecomePro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_pro_banner"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⭐ Passer à Blaze Pro"
                    android:textColor="@color/on_background"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-condensed" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- SECTION LECTURE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LECTURE"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingResume" layout="@layout/item_setting" />
            <include android:id="@+id/settingAutoPlay" layout="@layout/item_setting" />
            <include android:id="@+id/settingSpeed" layout="@layout/item_setting" />
            <include android:id="@+id/settingSeekTime" layout="@layout/item_setting" />
            <include android:id="@+id/settingOrientation" layout="@layout/item_setting" />
            <include android:id="@+id/settingPip" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION AUDIO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AUDIO"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingAudioLang" layout="@layout/item_setting" />
            <include android:id="@+id/settingRememberVolume" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION SOUS-TITRES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SOUS-TITRES"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingSubtitleDefault" layout="@layout/item_setting" />
            <include android:id="@+id/settingSubtitleLang" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION BLAZE AUDIO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BLAZE AUDIO"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingMiniPlayer" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION INTERFACE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INTERFACE"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingShowHidden" layout="@layout/item_setting" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION DONNÉES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DONNÉES"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingClearHistory" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="8dp" />

            <!-- SECTION À PROPOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="À PROPOS"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp" />

            <include android:id="@+id/settingAbout" layout="@layout/item_setting" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1FFFFFFF" android:layout_marginVertical="16dp" />

            <!-- RESTAURER ACHATS -->
            <LinearLayout
                android:id="@+id/btnRestorePurchases"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="?attr/selectableItemBackground"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/green_accent"
                    android:contentDescription="@null"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Restaurer les achats"
                    android:textColor="@color/green_accent"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-condensed" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
