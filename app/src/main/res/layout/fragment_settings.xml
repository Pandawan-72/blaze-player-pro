<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- HEADER avec bouton retour -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_surface_card"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Retour"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Réglages"
                android:textColor="@color/on_background"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- BOUTON DEVENIR PRO -->
        <LinearLayout
            android:id="@+id/btnBecomePro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_pro_entry"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_green_bordered"
                android:layout_marginEnd="14dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_flame"
                    android:tint="@color/green_accent"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Devenir Pro"
                    android:textColor="@color/on_background"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 jours gratuits · 3,99 € à vie"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/green_accent"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- BOUTON LECTURE -->
        <LinearLayout
            android:id="@+id/btnSectionPlayback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_green"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_play"
                    android:tint="@color/green_accent" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lecture" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ratio, vitesse, sauts, reprise"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>

        <!-- BOUTON DÉCODAGE -->
        <LinearLayout
            android:id="@+id/btnSectionDecoding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_blue"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_cpu"
                    android:tint="@color/blue_accent" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Décodage" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Matériel, HDR, mode auto"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>

        <!-- BOUTON SOUS-TITRES -->
        <LinearLayout
            android:id="@+id/btnSectionSubtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_purple"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_subtitles"
                    android:tint="@color/purple_accent" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sous-titres" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Taille, fond, décalage, ASS/SSA"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>

        <!-- BOUTON RÉSEAU -->
        <LinearLayout
            android:id="@+id/btnSectionNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_blue"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_wifi"
                    android:tint="@color/blue_accent" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Réseau" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Wi-Fi, cache, Chromecast"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>

        <!-- BOUTON INTERFACE -->
        <LinearLayout
            android:id="@+id/btnSectionInterface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_yellow"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_layout"
                    android:tint="@color/yellow_accent" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Interface" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Thème, langue, vue, tri"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>

        <!-- BOUTON À PROPOS -->
        <LinearLayout
            android:id="@+id/btnSectionAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_gray"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_info"
                    android:tint="@color/on_surface_variant" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="À propos" android:textColor="@color/on_surface"
                    android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Version, support, mentions légales"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/on_surface_variant" android:contentDescription="@null" />
        </LinearLayout>


        <!-- BOUTON DÉCONNEXION -->
        <LinearLayout
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_surface_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                android:tint="@color/on_surface_variant"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Effacer l'historique"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_surface_card"
            android:padding="13dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_red"
                android:layout_marginEnd="12dp">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="center" android:src="@drawable/ic_logout"
                    android:tint="@color/red_accent" android:contentDescription="@null" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Se déconnecter"
                android:textColor="@color/red_accent"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blaze Player · v1.0.0 · Retro-Spare"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
