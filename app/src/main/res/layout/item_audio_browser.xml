<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp"
    android:background="?attr/selectableItemBackground">

    <!-- Conteneur carte qui englobe tout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_surface_card"
        android:paddingHorizontal="10dp"
        android:paddingVertical="10dp">

        <!-- Checkbox dans la carte -->
        <CheckBox
            android:id="@+id/checkAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/green_accent"
            android:layout_marginEnd="10dp" />

        <!-- Cover artwork -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_thumbnail"
            android:clipToOutline="true"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/ivAudioCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:contentDescription="@null" />

        </FrameLayout>

        <!-- Titre + artiste + badges -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start">

            <TextView
                android:id="@+id/tvAudioTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tvAudioArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginBottom="5dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAudioCodec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvAudioBitrate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="sans-serif-condensed"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
        <!-- Durée -->
        <TextView
            android:id="@+id/tvAudioDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginStart="8dp"
            android:gravity="end" />

    </LinearLayout>

</LinearLayout>