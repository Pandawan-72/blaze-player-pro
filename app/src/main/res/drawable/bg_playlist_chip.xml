<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- État "playlist non vide" -->
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#263DD68C" />
            <stroke android:width="1.5dp" android:color="@color/green_accent" />
        </shape>
    </item>
    <!-- État "playlist vide" -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/surface_variant" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
        </shape>
    </item>
</selector>
