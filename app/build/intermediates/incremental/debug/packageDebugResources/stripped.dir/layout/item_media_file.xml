<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="5dp"
    android:background="@drawable/bg_media_card"
    android:foreground="?attr/selectableItemBackground"
    android:elevation="3dp">

    <!-- Case à cocher (sélection multiple) : cachée par défaut (listes sans sélection, ex: accueil),
         rendue visible par le navigateur quand la sélection est disponible. Positionnée à gauche,
         comme dans le navigateur audio. -->
    <CheckBox
        android:id="@+id/checkboxSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/green_accent"
        android:layout_marginEnd="10dp"
        android:visibility="gone" />

    <!-- Thumbnail -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_thumbnail"
        android:layout_marginEnd="12dp"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivPlayOverlay"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_circle"
            android:contentDescription="@null" />

        <!-- Conteneur (MP4, MKV...) en overlay bas-gauche de la miniature -->
        <TextView
            android:id="@+id/tvFormat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="4dp"
            android:background="#B3000000"
            android:paddingHorizontal="5dp"
            android:paddingVertical="1dp"
            android:textSize="9sp"
            android:textColor="@color/on_surface"
            android:fontFamily="sans-serif-condensed"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Infos : titre + badges + durée alignés à gauche -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start">

        <!-- Titre -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginBottom="5dp" />

        <!-- Badges : résolution/qualité | codec vidéo | codec audio -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvVideoCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="@color/blue_accent"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvAudioCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="sans-serif-condensed"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Durée • Résolution pixels -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <!-- 3 points -->
    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        android:tint="@color/on_surface_variant"
        android:contentDescription="Plus" />

    <!-- progressFill caché pour compatibilité -->
    <View
        android:id="@+id/progressFill"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
