<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_surface_card"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Retour"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reseau"
                android:textColor="@color/on_background"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:singleLine="true"
                android:ellipsize="middle" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_surface_card"
            android:src="@drawable/ic_search"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Rechercher"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_surface_card"
            android:src="@drawable/ic_home"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Accueil" />

    </LinearLayout>

    <!-- COMPTEUR + TRI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chargement..."
            android:textColor="@color/blue_accent"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_equalizer"
            android:tint="@color/on_surface_variant"
            android:layout_marginEnd="4dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvSortLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nom"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/btnSortChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_down"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Trier"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- BARRE DE SÉLECTION (playlist) -->
    <LinearLayout
        android:id="@+id/toolbarSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/green_accent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnCancelSelection"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:tint="#000000"
            android:contentDescription="Annuler" />

        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#000000"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"
            android:paddingStart="8dp" />

        <Button
            android:id="@+id/btnAddToPlaylist"
            android:includeFontPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Ajouter à la playlist"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#33000000"
            android:paddingHorizontal="14dp" />

    </LinearLayout>

    <!-- LISTE -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNetwork"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />

</LinearLayout>
