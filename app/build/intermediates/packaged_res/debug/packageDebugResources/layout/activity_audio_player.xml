<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- CONTENU PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="76dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_down"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Fermer" />

            <TextView
                android:id="@+id/tvNowPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="EN LECTURE"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.15" />

            <ImageButton
                android:id="@+id/btnPlaylistSheet"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_layout_list"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Playlist" />

        </RelativeLayout>

        <!-- ARTWORK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/ivArtwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_artwork"
                android:clipToOutline="true" />

        </LinearLayout>

        <!-- TITRE + ARTISTE + ICONES -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Titre inconnu"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-condensed"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:maxWidth="220dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artiste inconnu"
                    android:textColor="@color/green_accent"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvAlbum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </RelativeLayout>

        <!-- CODEC + BITRATE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tvCodec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="@color/blue_accent"
                android:fontFamily="sans-serif-condensed"
                android:text="MP3"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvBitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:fontFamily="sans-serif-condensed"
                android:visibility="gone" />

        </LinearLayout>

        <!-- SEEKBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/green_accent"
                android:thumbTint="@color/green_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-condensed" />

            </LinearLayout>

        </LinearLayout>

        <!-- CONTRÔLES PRINCIPAUX -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Aléatoire" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:tint="@color/on_surface"
                android:contentDescription="Précédent" />

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:contentDescription="-10s" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_play_button"
                android:src="@drawable/ic_play"
                android:tint="@color/background"
                android:padding="18dp"
                android:contentDescription="Lecture/Pause" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:contentDescription="+10s" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/on_surface"
                android:contentDescription="Suivant" />

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_repeat"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Répéter" />

        </LinearLayout>

        <!-- BOUTONS SECONDAIRES : EQ / SLEEP / INFOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/btnEq">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_equalizer"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="EQ" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Égaliseur"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Separateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#22FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/btnSleepTimer">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_timer"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Timer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minuteur"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Separateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#22FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/btnInfos">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_info"
                    android:tint="@color/on_surface_variant"
                    android:contentDescription="Infos" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Infos"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Playlists audio sauvegardées -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_layout_list"
                android:tint="@color/on_surface_variant"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlists"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/btnAudioPlaylist1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:background="@drawable/bg_playlist_chip"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnAudioPlaylist2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:background="@drawable/bg_playlist_chip"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnAudioPlaylist3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:fontFamily="sans-serif-condensed"
                android:background="@drawable/bg_playlist_chip"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Éléments cachés pour compatibilité -->
        <View android:id="@+id/ivPixelChar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/ivPixelCharLeft" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>

    <!-- PLAYLIST PLEIN ECRAN - simple overlay, pas de BottomSheet pour eviter conflits de scroll -->
    <LinearLayout
        android:id="@+id/playlistSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background"
        android:paddingBottom="76dp"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- Header FILE D'ATTENTE avec bouton Fermer explicite -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:background="@color/background">

            <ImageButton
                android:id="@+id/btnClosePlaylist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_down"
                android:tint="@color/on_surface"
                android:contentDescription="Fermer la playlist"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FILE D'ATTENTE"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1" />

            <ImageButton
                android:id="@+id/btnAddFolder"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add_circle"
                android:tint="@color/green_accent"
                android:contentDescription="Ajouter" />

            <ImageButton
                android:id="@+id/btnCleanPlaylist"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_remove_circle"
                android:tint="#FF4444"
                android:layout_marginStart="4dp"
                android:contentDescription="Nettoyer" />

        </LinearLayout>

        <!-- Bordure separatrice -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF" />

        <!-- Liste -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPlaylist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="always"
            android:paddingBottom="24dp"
            android:clipToPadding="false" />

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
